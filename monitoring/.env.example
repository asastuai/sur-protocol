# SUR Protocol - Monitoring & Alerting

NETWORK=testnet
RPC_URL=https://sepolia.base.org

# Contract addresses
VAULT_ADDRESS=0x...
ENGINE_ADDRESS=0x...
SETTLEMENT_ADDRESS=0x...
LIQUIDATOR_ADDRESS=0x...
INSURANCE_FUND_ADDRESS=0x...
ORACLE_ROUTER_ADDRESS=0x...

# Markets to monitor
MARKETS=BTC-USD,ETH-USD

# Keeper addresses to monitor for low balance (comma-separated)
KEEPER_ADDRESSES=0x...,0x...
MIN_KEEPER_BALANCE_ETH=0.01

# API WebSocket URL
WS_API_URL=ws://localhost:3002

# Check interval (ms)
CHECK_INTERVAL_MS=30000

# Telegram alerts (optional)
# Create bot via @BotFather, get chat ID via @userinfobot
#TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
#TELEGRAM_CHAT_ID=-1001234567890

# Discord alerts (optional)
# Create webhook in channel settings
#DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
