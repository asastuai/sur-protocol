# ============================================================
# ASTER DEX MOMENTUM SCALP BOT — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# ─── API CREDENTIALS ────────────────────────────────
# Get these from https://www.asterdex.com/en/api-management
ASTER_API_KEY=your_api_key_here
ASTER_API_SECRET=your_api_secret_here

# ─── ENDPOINTS ──────────────────────────────────────
REST_BASE_URL=https://fapi.asterdex.com
WS_BASE_URL=wss://fstream.asterdex.com

# ─── TRADING PARAMETERS ────────────────────────────
TRADE_SYMBOL=BTCUSDT
STARTING_CAPITAL=1000
POSITION_SIZE_PCT=5

# ─── LEVERAGE ───────────────────────────────────────
DEFAULT_LEVERAGE=15
LOW_VOL_LEVERAGE=20
HIGH_VOL_LEVERAGE=10
