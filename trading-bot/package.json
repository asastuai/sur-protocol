{
  "name": "aster-momentum-scalp-bot",
  "version": "1.0.0",
  "description": "Momentum Scalp Trading Bot for Aster DEX with paper trading mode",
  "scripts": {
    "paper": "bun run index.ts --paper --verbose",
    "paper:btc": "bun run index.ts --paper --symbol=BTCUSDT --verbose",
    "paper:eth": "bun run index.ts --paper --symbol=ETHUSDT --verbose",
    "paper:sol": "bun run index.ts --paper --symbol=SOLUSDT --verbose",
    "live": "bun run index.ts --live --verbose",
    "live:btc": "bun run index.ts --live --symbol=BTCUSDT --verbose",
    "live:eth": "bun run index.ts --live --symbol=ETHUSDT --verbose"
  },
  "dependencies": {},
  "devDependencies": {
    "bun-types": "latest"
  }
}
