# SUR Protocol - Keeper Bot Configuration

# Network (mainnet or testnet)
NETWORK=testnet

# RPC URLs for Base
RPC_URL=https://sepolia.base.org
# RPC_URL_WS=wss://sepolia.base.org  (optional, for real-time events)

# Keeper wallet private key (needs ETH for gas)
# This can be any wallet — liquidations are permissionless
KEEPER_PRIVATE_KEY=0x...

# Contract addresses (from deployment)
ENGINE_ADDRESS=0x...
LIQUIDATOR_ADDRESS=0x...
VAULT_ADDRESS=0x...

# How often to scan for liquidatable positions (ms)
SCAN_INTERVAL_MS=5000

# Block to start syncing events from (0 = current - 10000)
SYNC_FROM_BLOCK=0

# Max positions to liquidate in a single batch
MAX_BATCH_SIZE=10

# Minimum keeper reward to bother liquidating (USDC, 6 decimals)
# 100000 = $0.10, 1000000 = $1.00
MIN_REWARD_USDC=100000

# Markets to monitor
MARKETS=BTC-USD,ETH-USD
