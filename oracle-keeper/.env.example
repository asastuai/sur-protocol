# SUR Protocol - Oracle Price Keeper

# Network
NETWORK=testnet

# RPC
RPC_URL=https://sepolia.base.org

# Keeper wallet (needs ETH for gas + Pyth fees)
# Estimated cost: ~0.001 ETH per day on Base Sepolia
KEEPER_PRIVATE_KEY=0x...

# OracleRouter contract address (from deployment)
ORACLE_ROUTER_ADDRESS=0x...

# How often to push prices (ms). 5000 = every 5 seconds
PUSH_INTERVAL_MS=5000

# Pyth Hermes API (free, no API key needed)
HERMES_URL=https://hermes.pyth.network

# Safety: skip push if gas price exceeds this (gwei)
MAX_GAS_PRICE_GWEI=50

# Warn if balance drops below this (ETH)
MIN_BALANCE_ETH=0.005
