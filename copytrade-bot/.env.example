# SUR Protocol Copytrade Bot Configuration

# SUR Protocol API
SUR_API_URL=http://localhost:3003
SUR_WS_URL=ws://localhost:3002

# Your agent wallet (for live execution)
SUR_AGENT_ADDRESS=0x...
SUR_AGENT_KEY=...

# Primary trader to copy (discovered via --mode=profile)
PRIMARY_TRADER=0x...

# Risk management
CAPITAL=2000
MAX_POSITION_PCT=0.20
MAX_LEVERAGE=5
MAX_DAILY_LOSS_PCT=0.03

# Scanning
SCAN_INTERVAL_MS=3000
PROFILE_INTERVAL_MS=900000
